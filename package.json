{
  "name": "combox-api",
  "description": "TypeScript client library for ComBox frontend applications.",
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/combox/combox-api.git"
  },
  "homepage": "https://github.com/combox/combox-api",
  "bugs": {
    "url": "https://github.com/combox/combox-api/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build"
  },
  "dependencies": {
    "typescript": "~6.0.2"
  }
}
